{
  "name": "evolve-sdk-workspace",
  "private": true,
  "type": "module",
  "version": "0.0.31",
  "workspaces": [
    "packages/e2b",
    "packages/daytona",
    "packages/modal",
    "packages/docker",
    "packages/local",
    "packages/sandbox",
    "packages/microvm",
    "packages/sdk-ts",
    "packages/sdk-py/bridge",
    "docs-site"
  ],
  "scripts": {
    "build": "npm run build:e2b && npm run build:daytona && npm run build:modal && npm run build:docker && npm run build:local && npm run build:sandbox && npm run build:microvm && npm run build:sdk && npm run build:bridge",
    "build:e2b": "npm run build --workspace=@evolvingmachines/e2b",
    "build:daytona": "npm run build --workspace=@evolvingmachines/daytona",
    "build:modal": "npm run build --workspace=@evolvingmachines/modal",
    "build:docker": "npm run build --workspace=@evolvingmachines/docker",
    "build:local": "npm run build --workspace=@evolvingmachines/local",
    "build:sandbox": "npm run build --workspace=@evolvingmachines/sandbox",
    "build:microvm": "npm run build --workspace=@evolvingmachines/microvm",
    "build:sdk": "npm run build --workspace=@evolvingmachines/sdk",
    "build:bridge": "npm run build --workspace=evolve-sdk-python-bridge",
    "test:ts": "npm run test --workspace=@evolvingmachines/sdk",
    "test:ts:unit": "npm run test:unit --workspace=@evolvingmachines/sdk",
    "test:ts:integration": "npm run test:integration --workspace=@evolvingmachines/sdk",
    "test:py:unit": "npm run build:bridge && cd packages/sdk-py && python -m pytest tests/unit -v",
    "test:py:integration": "npm run build:bridge && cd packages/sdk-py && python -m pytest tests/integration -v",
    "test:local": "cd packages/local && npx tsx tests/local-sandbox.test.ts",
    "test:sandbox": "cd packages/sandbox && npx tsx tests/os-sandbox.test.ts",
    "docs:dev": "npm run dev --workspace=docs-site",
    "docs:build": "npm run build --workspace=docs-site",
    "docs:test": "npm run test --workspace=docs-site"
  },
  "devDependencies": {
    "tsx": "^4.20.5",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "@aws-sdk/s3-request-presigner": "^3.986.0",
    "@daytonaio/sdk": "^0.134.0",
    "dotenv": "^17.2.3",
    "e2b": "^2.10.3",
    "modal": "^0.6.0"
  }
}
